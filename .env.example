# Copy to .env and fill in for local development.

# Postgres connection string (Supabase project connection string in production,
# or a local/docker-compose Postgres for development)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/association_management

# Set to "false" only for a local Postgres without SSL (e.g. docker-compose).
# Leave unset (or anything other than "false") for Supabase.
DATABASE_SSL=false

# Secret used to sign JWTs. Generate a real random value for anything beyond
# local dev, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-every-environment

PORT=3000
NODE_ENV=development
